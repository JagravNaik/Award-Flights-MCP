LOCAL_AWARD_FEED_ENABLED=true
LOCAL_AWARD_FEED_PATH=./config/sample-awards.json
SEATS_AERO_ENABLED=false
SEATS_AERO_API_KEY=
AEROBASE_ENABLED=false
AEROBASE_API_KEY=
AEROBASE_API_BASE_URL=https://aerobase.app/api
AWARD_FLIGHT_DAILY_ENABLED=true
AWARD_FLIGHT_DAILY_API_KEY=
AWARD_FLIGHT_DAILY_MCP_URL=https://awardflightdaily.com/mcp-server/mcp
AWARD_TRAVEL_FINDER_ENABLED=false
AWARD_TRAVEL_FINDER_API_KEY=
AWARD_TRAVEL_FINDER_API_BASE_URL=https://awardtravelfinder.com/api/v1
AWARD_TRAVEL_FINDER_AIRLINES=british_airways,qatar,cathay_pacific,virgin_atlantic
APIFY_FLIGHT_AWARD_ENABLED=false
APIFY_API_TOKEN=
APIFY_FLIGHT_AWARD_ACTOR_ID=igolaizola/flight-award-scraper
APIFY_FLIGHT_AWARD_MAX_ITEMS=100
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=3000
PUBLIC_JSON_ADAPTER_CONFIG=./config/public-json-adapters.example.json
AWARD_CACHE_TTL_SECONDS=900
AWARD_DEFAULT_CONCURRENCY=2
AWARD_MAX_BRUTE_FORCE_QUERIES=250
AWARD_DEFAULT_DELAY_MS=250
AWARD_ALERTS_PATH=./data/alerts.json
AWARD_HISTORY_PATH=./data/history.json
AWARD_POINTS_WALLET_PATH=./data/points-wallet.json
HOTEL_RESULTS_PATH=./config/hotel-results.example.json
HOTEL_ALERTS_PATH=./data/hotel-alerts.json
TRANSFER_BONUSES_PATH=./config/transfer-bonuses.json
SEAT_MAPS_PATH=./config/seat-maps.example.json
FARE_CLASSES_PATH=./config/fare-classes.example.json

# Private browser collector. Run with:
# docker compose --profile collector run --rm award-flights-collector
COLLECTOR_ADAPTERS=ba-reward-flight-finder,virgin-reward-seat-checker
COLLECTOR_ROUTES_PATH=/app/config/collector-routes.example.json
COLLECTOR_HEADLESS=true
COLLECTOR_INTERVAL_MINUTES=0
COLLECTOR_OUTPUT_PATH=./data/collector-awards.json
COLLECTOR_DEBUG_DIR=./data/collector-debug
COLLECTOR_NAVIGATION_TIMEOUT_MS=45000
COLLECTOR_ACTION_DELAY_MS=1500
